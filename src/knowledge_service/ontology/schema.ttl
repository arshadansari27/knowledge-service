@prefix ks:    <http://knowledge.local/schema/> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .

# Knowledge type classes
ks:KnowledgeType   rdf:type rdfs:Class ; rdfs:label "Knowledge Type" .
ks:Claim           rdf:type rdfs:Class ; rdfs:subClassOf ks:KnowledgeType ; rdfs:label "Claim" .
ks:Fact            rdf:type rdfs:Class ; rdfs:subClassOf ks:KnowledgeType ; rdfs:label "Fact" .
ks:Event           rdf:type rdfs:Class ; rdfs:subClassOf ks:KnowledgeType ; rdfs:label "Event" .
ks:Entity          rdf:type rdfs:Class ; rdfs:subClassOf ks:KnowledgeType ; rdfs:label "Entity" .
ks:Relationship    rdf:type rdfs:Class ; rdfs:subClassOf ks:KnowledgeType ; rdfs:label "Relationship" .
ks:Conclusion      rdf:type rdfs:Class ; rdfs:subClassOf ks:KnowledgeType ; rdfs:label "Conclusion" .
ks:TemporalState   rdf:type rdfs:Class ; rdfs:subClassOf ks:KnowledgeType ; rdfs:label "Temporal State" .

# Properties
ks:confidence          rdf:type rdf:Property ; rdfs:label "confidence" .
ks:knowledgeType       rdf:type rdf:Property ; rdfs:label "knowledge type" .
ks:validFrom           rdf:type rdf:Property ; rdfs:label "valid from" .
ks:validUntil          rdf:type rdf:Property ; rdfs:label "valid until" .
ks:concludes           rdf:type rdf:Property ; rdfs:label "concludes" .
ks:derivedFrom         rdf:type rdf:Property ; rdfs:label "derived from" .
ks:inferenceMethod     rdf:type rdf:Property ; rdfs:label "inference method" .
ks:occurredAt          rdf:type rdf:Property ; rdfs:label "occurred at" .
ks:amount              rdf:type rdf:Property, owl:FunctionalProperty ; rdfs:label "amount" .
ks:currency            rdf:type rdf:Property, owl:FunctionalProperty ; rdfs:label "currency" .
ks:oppositePredicate   rdf:type rdf:Property ; rdfs:label "opposite predicate" .
ks:inversePredicate    rdf:type rdf:Property ; rdfs:label "inverse predicate" .
ks:transitivePredicate rdf:type rdf:Property ; rdfs:label "transitive predicate" .

# Domain predicates (canonical vocabulary for extraction)
ks:causes          rdf:type rdf:Property ; rdfs:label "causes" .
ks:increases       rdf:type rdf:Property ; rdfs:label "increases" .
ks:decreases       rdf:type rdf:Property ; rdfs:label "decreases" .
ks:inhibits        rdf:type rdf:Property ; rdfs:label "inhibits" .
ks:activates       rdf:type rdf:Property ; rdfs:label "activates" .
ks:is_a            rdf:type rdf:Property ; rdfs:label "is a" .
ks:part_of         rdf:type rdf:Property ; rdfs:label "part of" .
ks:located_in      rdf:type rdf:Property ; rdfs:label "located in" .
ks:created_by      rdf:type rdf:Property ; rdfs:label "created by" .
ks:depends_on      rdf:type rdf:Property ; rdfs:label "depends on" .
ks:related_to      rdf:type rdf:Property ; rdfs:label "related to" .
ks:contains        rdf:type rdf:Property ; rdfs:label "contains" .
ks:precedes        rdf:type rdf:Property ; rdfs:label "precedes" .
ks:follows         rdf:type rdf:Property ; rdfs:label "follows" .
ks:has_property    rdf:type rdf:Property ; rdfs:label "has property" .
ks:used_for        rdf:type rdf:Property ; rdfs:label "used for" .
ks:produced_by     rdf:type rdf:Property ; rdfs:label "produced by" .
ks:associated_with rdf:type rdf:Property ; rdfs:label "associated with" .

# Opposite predicate pairs
ks:increases       ks:oppositePredicate ks:decreases .
ks:activates       ks:oppositePredicate ks:inhibits .
ks:precedes        ks:oppositePredicate ks:follows .
ks:contains        ks:inversePredicate ks:part_of .
