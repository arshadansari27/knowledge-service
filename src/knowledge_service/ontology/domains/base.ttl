@prefix ks:   <http://knowledge.local/schema/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# --- Canonical predicates for domain-agnostic knowledge extraction ---

ks:causes a ks:Predicate ;
    rdfs:label "causes" ;
    ks:domain "base" ;
    ks:materialityWeight "0.5"^^xsd:float ;
    ks:oppositePredicate ks:inhibits ;
    ks:synonym "leads_to", "results_in", "triggers", "induces", "produces" .

ks:increases a ks:Predicate ;
    rdfs:label "increases" ;
    ks:domain "base" ;
    ks:materialityWeight "0.5"^^xsd:float ;
    ks:oppositePredicate ks:decreases ;
    ks:synonym "boosts", "enhances", "elevates", "raises", "improves",
               "upregulates", "amplifies", "stimulates" .

ks:decreases a ks:Predicate ;
    rdfs:label "decreases" ;
    ks:domain "base" ;
    ks:materialityWeight "0.5"^^xsd:float ;
    ks:oppositePredicate ks:increases ;
    ks:synonym "reduces", "lowers", "diminishes", "suppresses",
               "downregulates", "attenuates" .

ks:inhibits a ks:Predicate ;
    rdfs:label "inhibits" ;
    ks:domain "base" ;
    ks:materialityWeight "0.5"^^xsd:float ;
    ks:oppositePredicate ks:causes ;
    ks:synonym "blocks", "prevents" .

ks:activates a ks:Predicate ;
    rdfs:label "activates" ;
    ks:domain "base" ;
    ks:materialityWeight "0.5"^^xsd:float ;
    ks:synonym "promotes", "enables" .

ks:is_a a ks:Predicate ;
    rdfs:label "is a" ;
    ks:domain "base" ;
    ks:materialityWeight "0.5"^^xsd:float ;
    ks:synonym "type_of", "instance_of", "kind_of" .

ks:part_of a ks:Predicate ;
    rdfs:label "part of" ;
    ks:domain "base" ;
    ks:materialityWeight "0.5"^^xsd:float ;
    ks:synonym "component_of", "belongs_to", "member_of" .

ks:located_in a ks:Predicate ;
    rdfs:label "located in" ;
    ks:domain "base" ;
    ks:materialityWeight "0.5"^^xsd:float ;
    ks:synonym "based_in", "situated_in" .

ks:created_by a ks:Predicate ;
    rdfs:label "created by" ;
    ks:domain "base" ;
    ks:materialityWeight "0.5"^^xsd:float ;
    ks:synonym "authored_by", "made_by", "built_by", "developed_by" .

ks:depends_on a ks:Predicate ;
    rdfs:label "depends on" ;
    ks:domain "base" ;
    ks:materialityWeight "0.5"^^xsd:float ;
    ks:synonym "requires", "needs" .

ks:related_to a ks:Predicate ;
    rdfs:label "related to" ;
    ks:domain "base" ;
    ks:materialityWeight "0.3"^^xsd:float ;
    ks:synonym "connected_to", "linked_to" .

ks:contains a ks:Predicate ;
    rdfs:label "contains" ;
    ks:domain "base" ;
    ks:materialityWeight "0.5"^^xsd:float ;
    ks:inversePredicate ks:part_of ;
    ks:synonym "includes", "has", "comprises" .

ks:precedes a ks:Predicate ;
    rdfs:label "precedes" ;
    ks:domain "base" ;
    ks:materialityWeight "0.5"^^xsd:float ;
    ks:oppositePredicate ks:follows ;
    ks:synonym "before", "prior_to" .

ks:follows a ks:Predicate ;
    rdfs:label "follows" ;
    ks:domain "base" ;
    ks:materialityWeight "0.5"^^xsd:float ;
    ks:oppositePredicate ks:precedes ;
    ks:synonym "after", "subsequent_to" .

ks:has_property a ks:Predicate ;
    rdfs:label "has property" ;
    ks:domain "base" ;
    ks:materialityWeight "0.5"^^xsd:float .

ks:used_for a ks:Predicate ;
    rdfs:label "used for" ;
    ks:domain "base" ;
    ks:materialityWeight "0.5"^^xsd:float .

ks:produced_by a ks:Predicate ;
    rdfs:label "produced by" ;
    ks:domain "base" ;
    ks:materialityWeight "0.5"^^xsd:float .

ks:associated_with a ks:Predicate ;
    rdfs:label "associated with" ;
    ks:domain "base" ;
    ks:materialityWeight "0.3"^^xsd:float .
